# Production build — copy to `.env.production` before `npm run build`.
# Only VITE_* (embedded at build time). No secrets.

# Same-origin behind nginx (example UI on http://host:8080, nginx proxies /api):
# VITE_API_BASE_URL=http://localhost:8080/api

# Split processes (pm2 serve UI + API on another port) — use absolute API URL:
VITE_API_BASE_URL=http://127.0.0.1:3001/api

VITE_USE_MOCK_DATA=false
VITE_REALTIME_ENABLED=true

# Optional tuning (see docs/guides/OPTIMIZED_POLLING.md)
# VITE_POLL_MS_MACHINES=1000
# VITE_POLL_MS_MACHINE_DETAIL=1000
# VITE_DEBUG_API=false
