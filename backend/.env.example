# Copy to backend/.env on factory PC. Never commit real secrets.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=production_dashboard
DB_USER=postgres
DB_PASSWORD=change_me

# Required when NODE_ENV=production (audit fail-fast)
JWT_SECRET=change_me_to_64_random_hex_chars_minimum
JWT_EXPIRES_IN=24h

NODE_ENV=production
PORT=3001

# Performance tuning (~20 users, chart-heavy shifts)
AVAILABILITY_SYNC_INTERVAL=60
ANALYTICS_REFRESH_INTERVAL=60
# DB_POOL_MAX=50

# Optional: slow query warnings in production logs (default 1000ms)
# DB_SLOW_QUERY_MS=1000
# DB_LOG_QUERIES=false

# Optional: Speed Lab / downtime export — min zero-speed segment (seconds). Default 60 (≥1 min).
# DOWNTIME_MIN_STOP_SEC=60
