    {
      "id": 213,
      "type": "state-timeline",
      "title": "Speed states (≥1 run · 0–1 creep · 0 stop)",
      "datasource": {
        "type": "postgres",
        "uid": "mes-postgres"
      },
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "running": {
                  "color": "#73BF69",
                  "text": "running"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "creep": {
                  "color": "#FADE2A",
                  "text": "creep"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "stopped": {
                  "color": "#F2495C",
                  "text": "stopped"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "alignValue": "left",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "postgres",
            "uid": "mes-postgres"
          },
          "rawSql": "WITH buckets AS (\n          SELECT to_timestamp(floor(extract(epoch from (calculation_timestamp AT TIME ZONE 'Asia/Ho_Chi_Minh' AT TIME ZONE 'UTC')) / 30) * 30) AS t,\n            AVG(actual_speed) AS spd\n          FROM oee_calculations\n          WHERE $__timeFilter((calculation_timestamp AT TIME ZONE 'Asia/Ho_Chi_Minh' AT TIME ZONE 'UTC')) AND machine_id='$machine_id'\n          GROUP BY 1\n        )\n        SELECT t AS time, t + INTERVAL '30 seconds' AS time_end,\n          CASE WHEN spd >= 1 THEN 'running' WHEN spd > 0 THEN 'creep' ELSE 'stopped' END AS status\n        FROM buckets ORDER BY t"
        }
      ]
    },
