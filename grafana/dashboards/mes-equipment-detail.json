    {
      "id": 120,
      "type": "timeseries",
      "title": "Speed trend — actual vs target (m/min)",
      "datasource": {
        "type": "postgres",
        "uid": "mes-postgres"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "mode": "none"
            }
          },
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Target speed"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "dash": [
                    10,
                    10
                  ],
                  "fill": "dash"
                }
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FF9830",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Actual speed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#5794F2",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT to_timestamp(floor(extract(epoch from (calculation_timestamp AT TIME ZONE 'Asia/Ho_Chi_Minh' AT TIME ZONE 'UTC')) / 30) * 30) AS \"time\",\n        AVG(actual_speed) AS \"Actual speed\",\n        AVG(target_speed) AS \"Target speed\"\n       FROM oee_calculations\n       WHERE $__timeFilter((calculation_timestamp AT TIME ZONE 'Asia/Ho_Chi_Minh' AT TIME ZONE 'UTC')) AND machine_id='$machine_id'\n       GROUP BY 1 ORDER BY 1",
          "datasource": {
            "type": "postgres",
            "uid": "mes-postgres"
          }
        }
      ]
    },
    {
      "id": 121,
      "type": "state-timeline",
      "title": "Operational states Gantt",
      "datasource": {
        "type": "postgres",
        "uid": "mes-postgres"
      },
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
