                  "text": "stopped"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "error": {
                  "color": "#C4162A",
                  "text": "error"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "alignValue": "left",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "mergeValues": false,
        "rowHeight": 0.85
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "datasource": {
            "type": "postgres",
            "uid": "mes-postgres"
          },
          "rawSql": "SELECT\n          (status_start_time AT TIME ZONE 'Asia/Ho_Chi_Minh' AT TIME ZONE 'UTC') AS time,\n          (COALESCE(status_end_time, NOW()) AT TIME ZONE 'Asia/Ho_Chi_Minh' AT TIME ZONE 'UTC') AS time_end,\n          status::text AS status\n        FROM machine_status_history\n        WHERE machine_id='$machine_id'\n          AND (status_start_time AT TIME ZONE 'Asia/Ho_Chi_Minh' AT TIME ZONE 'UTC') <= $__timeTo()\n          AND (COALESCE(status_end_time, NOW()) AT TIME ZONE 'Asia/Ho_Chi_Minh' AT TIME ZONE 'UTC') >= $__timeFrom()\n        ORDER BY status_start_time"
        }
      ]
    },
