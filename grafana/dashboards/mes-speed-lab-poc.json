      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "mes-postgres" },
          "format": "table",
          "rawSql": "SELECT\n  (status_start_time AT TIME ZONE 'Asia/Ho_Chi_Minh') AS time,\n  COALESCE(status_end_time AT TIME ZONE 'Asia/Ho_Chi_Minh', NOW()) AS time_end,\n  status::text AS status\nFROM machine_status_history\nWHERE\n  machine_id = '$machine_id'\n  AND (status_start_time AT TIME ZONE 'Asia/Ho_Chi_Minh') <= $__timeTo()\n  AND COALESCE(status_end_time AT TIME ZONE 'Asia/Ho_Chi_Minh', NOW()) >= $__timeFrom()\nORDER BY status_start_time",
          "refId": "A"
        }
      ],
