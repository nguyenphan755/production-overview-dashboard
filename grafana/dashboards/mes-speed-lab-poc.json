      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "mes-postgres" },
          "format": "time_series",
          "rawSql": "SELECT\n  to_timestamp(floor(extract(epoch from (calculation_timestamp AT TIME ZONE 'Asia/Ho_Chi_Minh')) / 30) * 30) AS \"time\",\n  AVG(actual_speed) AS \"Actual speed (m/min)\",\n  AVG(target_speed) AS \"Target speed (m/min)\"\nFROM oee_calculations\nWHERE\n  $__timeFilter((calculation_timestamp AT TIME ZONE 'Asia/Ho_Chi_Minh'))\n  AND machine_id = '$machine_id'\nGROUP BY 1\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Speed trend (oee_calculations) — POC vs Speed Lab",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "mes-postgres" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "max": 100,
          "min": 0,
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 9 },
      "id": 2,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "mes-postgres" },
          "format": "time_series",
          "rawSql": "SELECT\n  to_timestamp(floor(extract(epoch from (calculation_timestamp AT TIME ZONE 'Asia/Ho_Chi_Minh')) / 30) * 30) AS \"time\",\n  AVG(oee) AS \"OEE\",\n  AVG(availability) AS \"Availability\",\n  AVG(performance) AS \"Performance\",\n  AVG(quality) AS \"Quality\"\nFROM oee_calculations\nWHERE\n  $__timeFilter((calculation_timestamp AT TIME ZONE 'Asia/Ho_Chi_Minh'))\n  AND machine_id = '$machine_id'\nGROUP BY 1\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "OEE components (aggregate)",
      "type": "timeseries"
    },
