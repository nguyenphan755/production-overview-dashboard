# Optional Grafana overrides (copy to grafana/.env)
# Postgres defaults come from root .env and backend/.env — no need to duplicate DB_PASSWORD.

# MES Grafana POC — standalone (port 3000)
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

GRAFANA_URL=http://localhost:3000

# Override only if different from backend/.env:
# GRAFANA_PG_HOST=host.docker.internal
# GRAFANA_PG_PORT=5432
# GRAFANA_PG_DATABASE=production_dashboard
# GRAFANA_PG_USER=grafana_readonly
# GRAFANA_PG_PASSWORD=
